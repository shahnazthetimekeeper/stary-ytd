name: starry-dl-audio
on:
  workflow_dispatch:
    inputs:
      url:
        description: 'YouTube video URL'
        required: true
        type: string

permissions:
  contents: write

jobs:
  download:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup yt-dlp
        uses: AnimMouse/setup-yt-dlp@v3

      - name: Decode and decompress cookies
        run: |
          echo "${{ secrets.YOUR_COOKIES }}" | base64 -d | gunzip > cookies.txt

      - name: Keep only last 10 audio files
        run: |
          mkdir -p music
          cd music
          # Delete all but the 10 most recent files
          ls -t *.mp3 *.m4a *.opus 2>/dev/null | tail -n +11 | xargs -r rm

      - name: Download audio only (highest quality)
        run: |
          yt-dlp --cookies cookies.txt "${{ inputs.url }}" \
            -x --audio-format best \
            --audio-quality 0 \
            -o "music/%(title)s_%(upload_date)s.%(ext)s"

      - name: Get audio filename
        id: filename
        run: |
          FILE=$(ls music/*.* | head -n 1)
          echo "file=$FILE" >> $GITHUB_OUTPUT
          EXT="${FILE##*.}"
          echo "ext=$EXT" >> $GITHUB_OUTPUT

      - name: Split audio into 95MB chunks (if needed)
        run: |
          cd music
          # Check file size and split if needed
          FILE_SIZE=$(stat -c%s "${{ steps.filename.outputs.file }}")
          if [ $FILE_SIZE -gt 100000000 ]; then
            split -b 95m "${{ steps.filename.outputs.file }}" "chunk_"
            
            # Create reassembly script
            echo '#!/bin/bash' > reassemble.sh
            echo 'cat chunk_* > reassembled_audio.${{ steps.filename.outputs.ext }}' >> reassemble.sh
            echo 'echo "Audio reassembled as reassembled_audio.${{ steps.filename.outputs.ext }}"' >> reassemble.sh
            chmod +x reassemble.sh
            
            # Remove original audio (only chunks remain)
            rm "${{ steps.filename.outputs.file }}"
          else
            echo "File under 100MB, no split needed"
          fi

      - name: Commit and push audio
        run: |
          git config user.name "GitHub Actions"
          git config user.email "github-actions@users.noreply.github.com"
          git add music/
          git commit -m "Add audio from ${{ inputs.url }}" || echo "No changes to commit"
          git push

      - name: Upload audio as artifact (backup)
        uses: actions/upload-artifact@v4
        with:
          name: audio-file
          path: music/
          retention-days: 7
